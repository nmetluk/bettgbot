# --- Docker ---
# локальный override (не infra/docker-compose.override.yml)
docker-compose.override.yml
!infra/docker-compose.override.yml

# --- Drive/Finder duplicates ---
# Ловит "brief 2.md", "notes 3.md", "data 2.yml" и т.п.
* [0-9].md
* [0-9].txt
* [0-9].yml
* [0-9].yaml
* [0-9].py
* [0-9].sh

# --- Mock-registry (если используется отдельный файл с реальными номерами для тестов) ---
infra/mock-registry.local.yml

# --- handoff (рабочие пометки исполнителя) ---
# сами файлы задач/отчётов коммитим; локальный draft — нет
handoff/.draft/

# --- Build metadata (baked into Docker images) ---
# Generated by scripts/generate_build_info.sh before every build.
# The file only exists inside containers.
src/shared/_build_info.py

# --- Claude Code runtime ---
.claude/

# --- GitHub PAT (read-only, cowork local) ---
.gh_pat
.config/
