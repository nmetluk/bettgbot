# Пример переменных окружения для Betting Bot.
# Скопируйте в .env (рядом с docker-compose.yml) и подставьте реальные значения.
# .env в репозиторий не коммитится.

# --- Environment ---
# dev (default) — локальная разработка через http (Secure cookie выключен).
# staging|prod — https-only, Secure обязателен.
ENVIRONMENT=dev

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- PostgreSQL ---
POSTGRES_USER=betting
POSTGRES_PASSWORD=changeme
POSTGRES_DB=betting

# DATABASE_URL — хост зависит от сценария запуска приложения:
#   • Локальный dev (приложение на хосте через `uv run`, БД в compose):
#       postgresql+asyncpg://betting:changeme@localhost:5432/betting
#   • Compose (приложение тоже в compose, см. TASK-026):
#       postgresql+asyncpg://betting:changeme@db:5432/betting
# Раскомментируй нужную строку; по умолчанию ниже — localhost (текущий dev-сценарий).
DATABASE_URL=postgresql+asyncpg://betting:changeme@localhost:5432/betting
# DATABASE_URL=postgresql+asyncpg://betting:changeme@db:5432/betting

# --- Redis ---
# Аналогично DATABASE_URL: localhost для dev (БД в compose), redis для compose-сценария.
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# --- Admin (веб-админка) ---
# Секрет для signed cookie. Сгенерировать: python -c "import secrets;print(secrets.token_urlsafe(64))"
ADMIN_SECRET_KEY=
ADMIN_SESSION_HOURS=8
# Отдельный секрет для CSRF (best practice — не переиспользуем session-secret).
# Сгенерировать: python -c "import secrets;print(secrets.token_urlsafe(48))"
ADMIN_CSRF_SECRET=
# Домен для admin-панели (prod nginx config)
ADMIN_DOMAIN=betgbot.example.com
TLS_EMAIL=admin@example.com

# --- External User Registry ---
# Какую реализацию проверки телефона использовать: mock | http
EXTERNAL_REGISTRY_BACKEND=mock

# Если EXTERNAL_REGISTRY_BACKEND=http
EXTERNAL_API_BASE_URL=
EXTERNAL_API_TOKEN=
EXTERNAL_API_TIMEOUT_CONNECT=2.0
EXTERNAL_API_TIMEOUT_READ=5.0

# Если EXTERNAL_REGISTRY_BACKEND=mock
# Путь к YAML-файлу с разрешёнными/заблокированными телефонами (см. docs/06-external-api.md)
MOCK_REGISTRY_FILE=infra/mock-registry.yml
# Альтернатива: список телефонов через запятую (приоритетнее файла)
MOCK_REGISTRY_ALLOWED=

# --- Logging ---
LOG_LEVEL=INFO
# console для dev (читаемо), json для prod (парсится jq/Loki/etc.)
LOG_FORMAT=console

# --- Scheduler ---
# Период тикания планировщика напоминаний, в секундах
REMINDER_TICK_SECONDS=300
