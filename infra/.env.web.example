# Environment variables required by the web (admin panel) service.
# For full list with descriptions, see .env.example

# --- Database ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Admin (веб-админка) ---
ADMIN_SECRET_KEY=
ADMIN_SESSION_HOURS=8
ADMIN_CSRF_SECRET=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Environment ---
ENVIRONMENT=dev
