# Environment variables required by the bot service.
# For full list with descriptions, see .env.example

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Database ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- External User Registry ---
EXTERNAL_REGISTRY_BACKEND=mock
EXTERNAL_API_BASE_URL=
EXTERNAL_API_TOKEN=
EXTERNAL_API_TIMEOUT_CONNECT=2.0
EXTERNAL_API_TIMEOUT_READ=5.0
MOCK_REGISTRY_FILE=infra/mock-registry.yml
MOCK_REGISTRY_ALLOWED=

# --- Scheduler ---
REMINDER_TICK_SECONDS=300

# --- Environment ---
ENVIRONMENT=dev
