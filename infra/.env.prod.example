# Prod-окружение Betting Bot.
# Скопируйте в .env на сервере и подставьте РЕАЛЬНЫЕ значения.
# Все секреты ДОЛЖНЫ быть сгенерированы заново (не использовать значения из dev).

# --- Environment ---
ENVIRONMENT=prod

# --- Telegram ---
# Получить у @BotFather. Формат: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz (≥35 символов)
TELEGRAM_BOT_TOKEN=YOUR_REAL_BOT_TOKEN_HERE

# --- PostgreSQL ---
POSTGRES_USER=betting
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=YOUR_GENERATED_PASSWORD_HERE
POSTGRES_DB=betting

# Для prod (приложение в docker-compose): хост = db
DATABASE_URL=postgresql+asyncpg://betting:YOUR_GENERATED_PASSWORD_HERE@db:5432/betting

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Admin (веб-админка) ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_SECRET_KEY=YOUR_GENERATED_SECRET_KEY_HERE
ADMIN_SESSION_HOURS=8
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_CSRF_SECRET=YOUR_GENERATED_CSRF_SECRET_HERE
# Домен для admin-панели (должен совпадать с nginx config)
ADMIN_DOMAIN=your-admin-domain.example.com
# Email для Let's Encrypt (TLS сертификат)
TLS_EMAIL=admin@your-domain.example.com

# --- External User Registry ---
# Для prod ОБЯЗАТЕЛЬНО использовать http (не mock!)
EXTERNAL_REGISTRY_BACKEND=http
EXTERNAL_API_BASE_URL=https://your-registry-api.example.com
EXTERNAL_API_TOKEN=YOUR_REGISTRY_API_TOKEN_HERE
EXTERNAL_API_TIMEOUT_CONNECT=2.0
EXTERNAL_API_TIMEOUT_READ=5.0

# --- Logging ---
LOG_LEVEL=INFO
# Для prod ОБЯЗАТЕЛЬНО json (для парсинга в Loki/jq)
LOG_FORMAT=json

# --- Scheduler ---
REMINDER_TICK_SECONDS=300

# --- Offsite Backup (TASK-039) ---
# ⚠️ ОБЯЗАТЕЛЬНО для prod: включите offsite encrypted backup
BACKUP_ENABLED=true
# ⚠️ Публичный ключ age (сгенерировать: age-keygen -o key.txt)
# Private ключ ХРАНИТСЯ ТОЛЬКО У ВЛАДЕЛЬЦА вне VPS!
BACKUP_AGE_RECIPIENT=age1your-public-key-here
# rclone remote (настроить заранее: rclone config)
# Примеры: b2:bettgbot-prod-backups, s3:bucket-name/backups
BACKUP_RCLONE_REMOTE=b2:bettgbot-prod-backups
BACKUP_RETENTION_DAYS=30
