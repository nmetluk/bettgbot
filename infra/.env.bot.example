# Environment variables required by the bot service.
# For full list with descriptions, see .env.example

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Database ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Scheduler ---
REMINDER_TICK_SECONDS=300

# --- Admin notifications via bot (TASK-097) ---
# CSV chat_id'ов админов (Telegram). Пусто → бот не шлёт дайджесты/сводки.
# Только bot-сервис; web не нуждается.
ADMIN_TELEGRAM_CHAT_IDS=

# --- Backup heartbeat (TASK-099, bot only) ---
# Включайте на ровно одном инстансе бота. Default false (безопасно).
BACKUP_HEARTBEAT_ENABLED=false
BACKUP_MAX_AGE_HOURS=2

# --- Environment ---
ENVIRONMENT=dev
