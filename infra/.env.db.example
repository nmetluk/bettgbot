# Environment variables required by database-related services (db, db-backup).
# For full list with descriptions, see .env.example

# --- PostgreSQL ---
POSTGRES_USER=betting
POSTGRES_PASSWORD=
POSTGRES_DB=betting

# --- Offsite Backup (db-backup only) ---
BACKUP_ENABLED=false
BACKUP_AGE_RECIPIENT=
BACKUP_RCLONE_REMOTE=
BACKUP_RETENTION_DAYS=30
