# Environment variables required by the bot service.
# For full list with descriptions, see .env.example

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Database ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Scheduler ---
REMINDER_TICK_SECONDS=300

# --- Environment ---
ENVIRONMENT=dev
