# Пример переменных окружения для Betting Bot.
# Скопируйте в .env (рядом с docker-compose.yml) и подставьте реальные значения.
# .env в репозиторий не коммитится.

# --- Environment ---
# dev (default) — локальная разработка через http (Secure cookie выключен).
# staging|prod — https-only, Secure обязателен.
ENVIRONMENT=dev

# --- Telegram ---
# ⚠️ Для prod: использовать реальный токен от BotFather (≥35 символов).
TELEGRAM_BOT_TOKEN=

# --- PostgreSQL ---
POSTGRES_USER=betting
# ⚠️ Для prod: сгенерируйте сильный пароль: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=changeme
POSTGRES_DB=betting

# DATABASE_URL — хост зависит от сценария запуска приложения:
#   • Локальный dev (приложение на хосте через `uv run`, БД в compose):
#       postgresql+asyncpg://betting:changeme@localhost:5432/betting
#   • Compose (приложение тоже в compose, см. TASK-026):
#       postgresql+asyncpg://betting:changeme@db:5432/betting
# Раскомментируй нужную строку; по умолчанию ниже — localhost (текущий dev-сценарий).
DATABASE_URL=postgresql+asyncpg://betting:changeme@localhost:5432/betting
# DATABASE_URL=postgresql+asyncpg://betting:changeme@db:5432/betting

# --- Redis ---
# Аналогично DATABASE_URL: localhost для dev (БД в compose), redis для compose-сценария.
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# --- Admin (веб-админка) ---
# ⚠️ Для prod: ОБЯЗАТЕЛЬНО сгенерируйте сильный секрет (≥32 символов):
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_SECRET_KEY=
ADMIN_SESSION_HOURS=8
# ⚠️ Для prod: ОБЯЗАТЕЛЬНО сгенерируйте отдельный сильный секрет для CSRF:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_CSRF_SECRET=
# Домен для admin-панели (prod nginx config)
ADMIN_DOMAIN=betgbot.example.com
TLS_EMAIL=admin@example.com

# --- Logging ---
LOG_LEVEL=INFO
# console для dev (читаемо), json для prod (парсится jq/Loki/etc.)
LOG_FORMAT=console

# --- Scheduler ---
# Период тикания планировщика напоминаний, в секундах
REMINDER_TICK_SECONDS=300

# --- Offsite Backup (TASK-039) ---
# Для prod: включите offsite encrypted backup
# BACKUP_ENABLED=false для dev, BACKUP_ENABLED=true для prod
BACKUP_ENABLED=false
# Публичный ключ age для шифрования (сгенерировать: age-keygen -o key.txt)
# Private ключ ХРАНИТСЯ ТОЛЬКО У ВЛАДЕЛЬЦА вне VPS!
BACKUP_AGE_RECIPIENT=
# rclone remote (например b2:bettgbot-backups или s3:bucket/path)
BACKUP_RCLONE_REMOTE=
# Сколько дней хранить бэкапы (default: 30)
BACKUP_RETENTION_DAYS=30

# --- Image Tagging (TASK-042) ---
# Тег образа для bot/web сервисов из GHCR
# В prod используйте явный SHA (например abc1234) для точности версии
# Для dev можно использовать latest
IMAGE_TAG=latest
